{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "QuantVault",
  "version": "0.7.0",
  "identifier": "com.quantvault.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev:web",
    "beforeBuildCommand": "pnpm build:web"
  },
  "app": {
    "windows": [
      {
        "title": "QuantVault — 量化分析工作站",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://update.quantvault.app/check/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": "REPLACE_WITH_YOUR_PUBLIC_KEY",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "copyright": "Copyright (c) 2024-2026 QuantVault. 保留所有权利。",
    "category": "Finance",
    "shortDescription": "本地量化分析工作站",
    "longDescription": "QuantVault 是一款完全本地离线的桌面量化分析工具，面向中国大陆A股投资者。\n\n功能模块：\n· K线图分析（蜡烛图、Heikin Ashi、折线图）\n· 316+ 技术指标（230+免费 + 86专业版）\n· 交互式绘图工具（趋势线、斐波那契、矩形等）\n· 策略编写与回测（ME Script DSL）\n· 股票扫描器、筹码分布、形态识别\n· 交易日志、风控分析、多资产组合管理\n· 完全本地数据，无需联网",
    "windows": {
      "wix": {
        "language": "zh-CN",
        "bannerPath": null,
        "dialogImagePath": null
      },
      "nsis": {
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": true,
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "startMenuFolder": "QuantVault"
      }
    }
  }
}
