{
  "name": "@me/app",
  "version": "0.9.0",
  "private": true,
  "description": "桌面应用主入口",
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite",
    "build": "tsc && vite build && tauri build",
    "build:web": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "@me/chart-engine": "workspace:*",
    "@me/ui": "workspace:*",
    "@tauri-apps/api": "^2.0",
    "@tauri-apps/plugin-dialog": "^2.0",
    "react": "^18.3",
    "react-dom": "^18.3",
    "react-router-dom": "^6.23",
    "zustand": "^4.5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0",
    "@typescript-eslint/eslint-plugin": "^7.0",
    "@typescript-eslint/parser": "^7.0",
    "@vitejs/plugin-react": "^4.3",
    "eslint": "^8.57",
    "eslint-plugin-react": "^7.34",
    "eslint-plugin-react-hooks": "^4.6",
    "prettier": "^3.2",
    "typescript": "^5.4",
    "vite": "^5.4"
  }
}
